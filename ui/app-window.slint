// =============================================================================
// Top-Level Application Window (`ui/app-window.slint`)
// =============================================================================
// Main Slint window definition for Oryn. Disables standard OS frame decorations
// to use the custom Titlebar component. Defines font assignments across the app:
// - `Open Sans` for all general UI controls, menus, labels, chrome and everything.
// - `Literata` only for the main note writing canvas where users type their notes.
// - `Kode Mono` only for code blocks and monospaced text.

import { Tokens } from "./shared/tokens.slint";
import { Titlebar } from "./titlebar/titlebar.slint";
import { Sidebar, SidebarProject, SidebarConversation } from "./left-sidebar/left-sidebar.slint";
import { MainContent } from "./main-content/main-content.slint";
import { MarkdownElement } from "./markdown/markdown.slint";

export component AppWindow inherits Window {
    // Default window geometry setup
    preferred-width: 960px;
    preferred-height: 600px;
    min-width: 800px;
    min-height: 450px;

    // Disable native window frame decorations to use our custom Slint titlebar
    no-frame: true;

    // State properties for window layout & sidebar
    in-out property <bool> window_maximized: false;
    in-out property <float> ui_scale: 1.0;
    in-out property <bool> sidebar_open: true;
    in-out property <length> sidebar_width: 240px;

    // Sidebar data properties & active indexes
    in property <[SidebarProject]> sidebar_projects: [];
    in property <[SidebarConversation]> sidebar_chats: [];
    in-out property <int> active_project_index: -1;
    in-out property <int> active_conversation_index: -1;
    in-out property <int> active_chat_index: -1;

    // Main document text content & Markdown AST element model
    in-out property <string> editor_text: "";
    in property <[MarkdownElement]> markdown_elements: [];

    // Dynamically disable window resize border when maximized/fullscreen
    // so hovering window edges in fullscreen mode does not trigger resize cursor.
    resize-border-width: root.window_maximized ? 0px : Tokens.window_resize_border_width;

    // Window surface properties
    background: Tokens.window_background;
    title: "Oryn";
    icon: @image-url("../assets/brand/icon.svg");

    // Global font styling rules for general UI controls
    default-font-family: Tokens.font_family;
    default-font-size: Tokens.body_font_size;
    default-font-weight: 400;

    // Callbacks exposed to host Rust backend
    callback minimize_requested();
    callback maximize_requested();
    callback close_window_requested();
    callback exit_requested();
    callback drag_window_requested();
    callback undo_requested();
    callback redo_requested();

    callback new_document_requested();
    callback open_project_requested();
    callback new_project_document_requested(string, int);

    callback project_document_clicked(string, int, int);
    callback general_document_clicked(string, int);

    callback delete_general_document_requested(string, int);
    callback delete_project_document_requested(string, int, int);
    callback delete_project_requested(string, int);

    callback search_query_changed(string);
    callback rename_requested(string /* target_path */, string /* new_name */, string /* target_type */);
    callback move_to_requested(string /* file_path */);
    callback pin_document_requested(string /* file_path */);
    callback pin_project_requested(string /* project_workspace */);

    callback open_file_requested();
    callback save_file_requested();
    callback settings_requested();

    // -------------------------------------------------------------------------
    // Main Workspace Layout
    // -------------------------------------------------------------------------
    // Positioned directly below the titlebar. Includes resizable left sidebar
    // and note editing canvas with clean borderless edges.
    HorizontalLayout {
        x: 0px;
        y: titlebar.height;
        width: parent.width;
        height: parent.height - titlebar.height;
        spacing: 0px;

        // ---------------------------------------------------------------------
        // Resizable Left Sidebar Component
        // ---------------------------------------------------------------------
        sidebar := Sidebar {
            sidebar_width <=> root.sidebar_width;
            width: root.sidebar_open ? self.sidebar_width : 0px;
            visible: root.sidebar_open;
            horizontal-stretch: 0;

            projects: root.sidebar_projects;
            chats: root.sidebar_chats;
            active_project_index <=> root.active_project_index;
            active_conversation_index <=> root.active_conversation_index;
            active_chat_index <=> root.active_chat_index;

            settings_clicked => { root.settings_requested(); }
            new_chat_clicked => { root.new_document_requested(); }
            new_project_clicked => { root.open_project_requested(); }
            new_session_clicked(proj_path, proj_idx) => { root.new_project_document_requested(proj_path, proj_idx); }
            
            project_conversation_clicked(file_path, proj_idx, conv_idx) => { root.project_document_clicked(file_path, proj_idx, conv_idx); }
            chat_clicked(file_path, chat_idx) => { root.general_document_clicked(file_path, chat_idx); }

            delete_chat_clicked(file_path, chat_idx) => { root.delete_general_document_requested(file_path, chat_idx); }
            delete_conversation_clicked(file_path, proj_idx, conv_idx) => { root.delete_project_document_requested(file_path, proj_idx, conv_idx); }
            delete_project_clicked(proj_path, proj_idx) => { root.delete_project_requested(proj_path, proj_idx); }

            search_query_changed(query) => { root.search_query_changed(query); }
            search_cancelled => { root.search_query_changed(""); }

            rename_chat_saved(file_path, new_name, _chat_idx) => {
                root.rename_requested(file_path, new_name, "document");
            }

            rename_conversation_saved(file_path, new_name, _proj_idx, _conv_idx) => {
                root.rename_requested(file_path, new_name, "document");
            }

            rename_project_saved(proj_path, new_name, _proj_idx) => {
                root.rename_requested(proj_path, new_name, "project");
            }

            move_to_chat_clicked(file_path, chat_idx) => {
                root.move_to_requested(file_path);
            }

            move_to_conversation_clicked(file_path, proj_idx, conv_idx) => {
                root.move_to_requested(file_path);
            }

            pin_chat_clicked(file_path, chat_idx) => {
                root.pin_document_requested(file_path);
            }

            pin_conversation_clicked(file_path, proj_idx, conv_idx) => {
                root.pin_document_requested(file_path);
            }

            pin_project_clicked(proj_path, proj_idx) => {
                root.pin_project_requested(proj_path);
            }
        }

        // ---------------------------------------------------------------------
        // Scrollable Main Content Workspace Component
        // ---------------------------------------------------------------------
        content_workspace := MainContent {
            editor_text <=> root.editor_text;
            markdown_elements: root.markdown_elements;
        }
    }

    // -------------------------------------------------------------------------
    // Global Touch Dismiss Area for Dropdown Menus
    // -------------------------------------------------------------------------
    // Dismisses open dropdown menu panels when clicking anywhere on the main canvas.
    global_dismiss_area := TouchArea {
        x: 0px;
        y: Tokens.titlebar_height;
        width: parent.width;
        height: parent.height - Tokens.titlebar_height;
        enabled: titlebar.active_menu != 0;
        clicked => {
            titlebar.active_menu = 0;
        }
    }

    // -------------------------------------------------------------------------
    // Top Custom Titlebar Component Integration
    // -------------------------------------------------------------------------
    titlebar := Titlebar {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: Tokens.titlebar_height;
        is_maximized: root.window_maximized;
        ui_scale: root.ui_scale;
        sidebar_open: root.sidebar_open;

        sidebar_toggle_requested => {
            root.sidebar_open = titlebar.sidebar_open;
        }

        minimize_requested => { root.minimize_requested(); }
        maximize_requested => { root.maximize_requested(); }
        close_window_requested => { root.close_window_requested(); }
        exit_requested => { root.exit_requested(); }
        drag_window_requested => { root.drag_window_requested(); }
        undo_requested => { root.undo_requested(); }
        redo_requested => { root.redo_requested(); }
        new_document_requested => { root.new_document_requested(); }
        open_project_requested => { root.open_project_requested(); }
        open_file_requested => { root.open_file_requested(); }
        save_file_requested => { root.save_file_requested(); }
        settings_requested => { root.settings_requested(); }
    }
}
