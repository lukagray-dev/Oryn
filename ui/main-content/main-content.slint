// =============================================================================
// Oryn Main Content Component (`ui/main-content/main-content.slint`)
// =============================================================================
// Main document workspace canvas for Oryn with web-like smooth scrolling & custom scrollbar.
// Integrates the MarkdownView rendering engine for GitHub-flavored document display.

import { Tokens } from "../shared/tokens.slint";
import { MarkdownView, MarkdownElement } from "../markdown/markdown.slint";

// Exported main content workspace component.
export component MainContent inherits Rectangle {
    // Document state property for the raw Markdown text
    in-out property <string> editor_text: "";
    // Structured Markdown AST block elements model
    in property <[MarkdownElement]> markdown_elements: [];

    // Callback for text modifications
    callback text_changed(string);

    horizontal-stretch: 1;
    background: Tokens.window_background;

    // Smooth scrollable viewport container
    flickable := Flickable {
        width: parent.width;
        height: parent.height;
        viewport-height: content_layout.preferred-height;
        interactive: true;

        // Smooth ease-out animated interpolation on scroll position for web-like fluid scrolling
        animate viewport-y {
            duration: 150ms;
            easing: ease-out;
        }

        content_layout := VerticalLayout {
            padding-left: 48px;
            padding-right: 48px;
            padding-top: 36px;
            padding-bottom: 48px;
            width: parent.width;

            // -----------------------------------------------------------------
            // GitHub-Flavored Markdown View Rendering Engine
            // -----------------------------------------------------------------
            MarkdownView {
                elements: root.markdown_elements;
            }
        }
    }

    // -------------------------------------------------------------------------
    // Custom Slim & Stylish Theme Scrollbar
    // -------------------------------------------------------------------------
    scrollbar_track := Rectangle {
        x: parent.width - 10px;
        y: 6px;
        width: 6px;
        height: parent.height - 12px;
        background: transparent;
        visible: flickable.viewport-height > flickable.height;

        scrollbar_thumb := Rectangle {
            x: thumb_touch.has-hover || thumb_touch.pressed ? 0px : 1px;
            width: thumb_touch.has-hover || thumb_touch.pressed ? 6px : 4px;
            border-radius: 3px;
            
            // Calculate proportional thumb height
            height: max(32px, parent.height * (flickable.height / max(1px, flickable.viewport-height)));
            
            // Calculate thumb position corresponding to viewport-y scroll offset
            y: max(0px, min(parent.height - self.height, (parent.height - self.height) * (-flickable.viewport-y / max(1px, flickable.viewport-height - flickable.height))));
            
            // Theme matched colors with smooth hover transitions
            background: thumb_touch.pressed
                ? Tokens.accent_blue
                : (thumb_touch.has-hover ? #4a4a4a : #2e2e2e);
                
            animate background { duration: 150ms; }
            animate width { duration: 150ms; }
            animate x { duration: 150ms; }

            thumb_touch := TouchArea {
                mouse-cursor: pointer;
            }
        }
    }
}
