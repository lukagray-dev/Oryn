// =============================================================================
// Markdown Inline Code Styling Component (`ui/markdown/code.slint`)
// =============================================================================
// Defines tokens and styling constants for monospaced inline code snippets (`Kode Mono`).

import { Tokens } from "../shared/tokens.slint";

export global CodeTokens {
    // Monospace font family for inline code & technical text
    in property <string> font_family: Tokens.code_font_family;
    // GitHub-style dark inline code text color (#79c0ff)
    in property <color> text_color: Tokens.code_text_color;
    // GitHub-style dark inline code background container (#6e768133)
    in property <color> bg_code: Tokens.code_bg_color;
    // Border radius for capsule-like inline code container chips (6px)
    in property <length> border_radius: 6px;
    // Padding inside inline code chips
    in property <length> padding_x: 4px;
    in property <length> padding_y: 2px;
}

// Exported component for rendering standalone capsule inline code chips
export component MarkdownCodeSnippet inherits Rectangle {
    in property <string> code: "";
    background: CodeTokens.bg_code;
    border-radius: CodeTokens.border_radius;
    border-width: 1px;
    border-color: #30363d;

    HorizontalLayout {
        padding-left: CodeTokens.padding_x;
        padding-right: CodeTokens.padding_x;
        padding-top: CodeTokens.padding_y;
        padding-bottom: CodeTokens.padding_y;

        Text {
            text: root.code;
            font-family: CodeTokens.font_family;
            font-size: Tokens.body_font_size;
            color: CodeTokens.text_color;
            vertical-alignment: center;
        }
    }
}
