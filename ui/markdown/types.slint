// =============================================================================
// Markdown Type Definitions (`ui/markdown/types.slint`)
// =============================================================================
// Shared struct definitions for Markdown AST elements, table cells, and rows.

export struct InlineSpan {
    text: string,
    is_bold: bool,
    is_italic: bool,
    is_code: bool,
    is_strikethrough: bool,
}

// Struct representing a single table cell
// alignment: 0 = Left, 1 = Center, 2 = Right
export struct MarkdownTableCell {
    text: string,
    rich_text: styled-text,
    alignment: int,
    is_header: bool,
}

// Struct representing a single table row
export struct MarkdownTableRow {
    cells: [MarkdownTableCell],
    is_header: bool,
}
