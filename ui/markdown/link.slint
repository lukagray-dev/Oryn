// =============================================================================
// Markdown Link Component (`ui/markdown/link.slint`)
// =============================================================================
// Renders GitHub-flavored Markdown hyperlinks with accent blue typography (`Tokens.accent_blue`),
// hand pointer cursor on hover, and active `TouchArea` callback to open URLs in the default browser.

import { Tokens } from "../shared/tokens.slint";

export component MarkdownLink inherits Rectangle {
    in property <styled-text> rich_text;
    in property <string> url: "";
    callback open-url(string);

    horizontal-stretch: 1;
    height: link_text.preferred-height + 4px;

    link_text := StyledText {
        x: 0px;
        y: 0px;
        width: parent.width;
        text: root.rich_text;
        default-font-family: Tokens.editor_font_family;
        default-font-size: Tokens.body_font_size;
        default-color: Tokens.accent_blue;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;

        clicked => {
            if (root.url != "") {
                root.open-url(root.url);
            }
        }
    }
}
