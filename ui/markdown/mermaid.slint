// =============================================================================
// Markdown Mermaid Diagram Renderer Component (`ui/markdown/mermaid.slint`)
// =============================================================================
// Renders GitHub-flavored Mermaid diagrams directly as vector images with exact
// preferred-height layout sizing to eliminate excess vertical gaps.

import { Tokens } from "../shared/tokens.slint";

export component MarkdownMermaid inherits Rectangle {
    in property <image> diagram_image;

    horizontal-stretch: 1;
    height: diagram_img.preferred-height + 8px;

    diagram_img := Image {
        x: 0px;
        y: 4px;
        width: parent.width;
        source: root.diagram_image;
        image-fit: contain;
    }
}
