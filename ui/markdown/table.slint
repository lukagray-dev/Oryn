// =============================================================================
// Markdown Table Renderer Component (`ui/markdown/table.slint`)
// =============================================================================
// Renders GitHub-flavored Markdown tables with aligned grid columns, headers,
// zebra-striping, alignment (Left/Center/Right), and rich text (bold, italic, code).
// Resizes responsively with window size (`width: 100%`).

import { Tokens } from "../shared/tokens.slint";
import { MarkdownTableRow, MarkdownTableCell } from "./types.slint";

export component MarkdownTable inherits VerticalLayout {
    in property <[MarkdownTableRow]> rows: [];

    padding-top: 12px;
    padding-bottom: 12px;
    width: 100%;

    Rectangle {
        border-width: 1px;
        border-color: Tokens.border_default;
        border-radius: 6px;
        clip: true;
        background: #0d1117;
        width: 100%;

        GridLayout {
            spacing: 0px;
            padding: 0px;
            width: 100%;

            for row[r] in root.rows : Row {
                for cell[c] in row.cells : Rectangle {
                    background: row.is_header ? #161b22 : (Math.mod(r, 2) == 1 ? #161b22 : #0d1117);
                    border-width: 0.5px;
                    border-color: Tokens.border_default;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        padding-top: 8px;
                        padding-bottom: 8px;

                        StyledText {
                            text: cell.rich_text;
                            default-font-family: Tokens.editor_font_family;
                            default-font-size: Tokens.body_font_size;
                            default-color: Tokens.text_primary;
                            horizontal-alignment: cell.alignment == 1 ? center : (cell.alignment == 2 ? right : left);
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
