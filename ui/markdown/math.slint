// =============================================================================
// Markdown Display Math Component (`ui/markdown/math.slint`)
// =============================================================================
// Renders GitHub-flavored centered display math formulas (`$$...$$`) without a container box.

import { Tokens } from "../shared/tokens.slint";

export component MarkdownDisplayMath inherits VerticalLayout {
    in property <styled-text> rich_text;

    padding-top: 12px;
    padding-bottom: 12px;
    width: 100%;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        width: 100%;

        StyledText {
            text: root.rich_text;
            default-font-family: Tokens.editor_font_family;
            default-font-size: Tokens.editor_font_size;
            default-color: #a5d6ff;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
