// =============================================================================
// Markdown Horizontal Rule Component (`ui/markdown/rule.slint`)
// =============================================================================
// Renders GitHub-flavored Markdown thematic break dividers (`---`, `***`, `___`).

import { Tokens } from "../shared/tokens.slint";

export component MarkdownRule inherits VerticalLayout {
    padding-top: 16px;
    padding-bottom: 16px;

    Rectangle {
        height: 1px;
        background: Tokens.border_default;
    }
}
